options(scipen = 999)
### 7. Parameter Optimization Loop ###
Reset_weight_range = TRUE
ncore = 78
# Outer loop: multiple training rounds
t3 = Sys.time()
times = 1 # for test
rgs_df_list = list()
# Incorporate best weights from previous round
if (exists("rgs_df_top1")) {
message("\n[times ", times, "] Add the optimal weights of the previous training time (times = ", times - 1, ") to this training time (times = ", times, ") and save it in the results of the 0 iteration (iter = 0).")
re_best = as.numeric(rgs_df_top1[1,])
re_best[25] = 0
weights_best = re_best[6:24]
}
# Initialize weight search bounds
if (times == 1 && Reset_weight_range) {
message("\n[times ", times, "] Reset initial weight range.")
weights_min = c(rep(0, 18), 0.9)
# weights_min = c(rep(0, 18), 4000) # for test
# weights_max = c(rep(1, 18), nrow(interest_cell_type_peak_TG_pred_bak[[1]][[level]][["peak_TG"]])) # for test
# weights_max = c(rep(1, 18), 5000) # for test
if (dataset == "BM") {
weights_max = c(rep(1, 18), nrow(interest_cell_type_peak_TG_pred_bak[[1]][[level]][["peak_TG"]]) / 10)
} else if (dataset == "GM12878") {
weights_max = c(rep(1, 18), nrow(interest_cell_type_peak_TG_pred_bak[[1]][[level]][["peak_TG"]]) / 10)
} else if (dataset == "A549") {
weights_max = c(rep(1, 18), nrow(interest_cell_type_peak_TG_pred_bak[[1]][[level]][["peak_TG"]]) / 4)
} else {stop("Error.")}
} else {
message("\n[times ", times, "] Initialize the initial weight range of this training time (times = ", times, ") based on the optimal parameter value of previous training time (times = ", times - 1, ") .")
# weight_range_update_expansion = max(0.02, min(0.8 / times, 0.3))
weight_range_update_expansion = max(0.02, min(0.1 / times, 0.3))
# weight_range_update_expansion = 0.02
# weight_range_update_expansion = 0.1
weights_min = weights_best * (1 - weight_range_update_expansion)
weights_max = weights_best * (1 + weight_range_update_expansion)
weights_max[weights_max == 0] = 1
}
# Inner loop: iterations within a round
t1 = Sys.time()
for (iter in 1:1) {
# iter = 1 # for test
t11 = Sys.time()
message("\n[times-", times, ", iteration-", iter, "]")
nhead = max(40 - iter * 2, 5)
# nhead = max(20 - iter * 2, 2) + 2
# nhead = 10
# nsamp = ncore * 2
# nsamp = ncore * 10
nsamp = ncore * 100
# Parallel execution
t12 = Sys.time()
rgs0 = parallel::mclapply(1:nsamp, run_single_iteration, mc.cores = ncore)
print(Sys.time()-t12)
# Combine results
