weight_TG_count_percentile1, weight_peak_count_percentile1,
weight_theta_i1, weight_theta_i_percentile1,
weight_theta_p1, weight_theta_p_percentile1,
weight_fit_loss1, weight_fit_loss_percentile1
)
percentiles = with(peaks_df, cbind(
Accessibility, Expression,
Accessibility_percentile, Expression_percentile,
Accessibility_non_zero_ratio, Expression_non_zero_ratio,
Accessibility_non_zero_ratio_percentile, Expression_non_zero_ratio_percentile,
peak_importance_score, peak_importance_score_percentile,
TG_importance_score, TG_importance_score_percentile,
peak_TG_importance_score, peak_TG_importance_score_percentile,
TG_count, peak_count,
TG_count_percentile, peak_count_percentile,
theta_i, theta_i_percentile,
theta_p, theta_p_percentile,
fit_loss, fit_loss_percentile
))
peaks_df$TF_peak_IS = c(percentiles %*% weights)
return(list(peaks = as.data.frame(peaks_df)))
})
names(optimized_results) = tfs
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]] = optimized_results
for (tf in tfs) {
if (IS_threshold > max(interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]]$TF_peak_IS)) {
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]] =
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]] %>%
dplyr::top_n(npeaks_min, TF_peak_IS)
} else {
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]] =
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]] %>%
dplyr::filter(TF_peak_IS > IS_threshold)
}
message(tf, "  ", nrow(interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]]))
}
tfs_tgs = list()
for (tf in tfs) {
tfs_tgs[[tf]] = data.frame(
TF = rep(tf, nrow( interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]])),
TG =  interest_cell_type_TF_peak_pred[[1]][[level]][["TF_peaks"]][[tf]][["peaks"]][["SYMBOL"]]
)
}
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_TGs"]] = dplyr::bind_rows(tfs_tgs)
interest_cell_type_TF_peak_pred[[1]][[level]][["TF_TGs"]] = dplyr::distinct( interest_cell_type_TF_peak_pred[[1]][[level]][["TF_TGs"]])
rm(tfs, level, tf, optimized_results, tfs_tgs)
}
saveRDS(interest_cell_type_TF_peak_pred, file = "./5 Infer GRN/interest_cell_type_TF_peak_pred.rds")
qs::qsave(interest_cell_type_TF_peak_pred, "./interest_cell_type_TF_peak_pred.qsave")
