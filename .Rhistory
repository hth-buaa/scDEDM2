weights_min = apply(rgs_df_top[, -c(1:5, ncol(rgs_df_top))], 2, min, na.rm = TRUE)
message("\n[times-", times, ", iteration-", iter, "] Updated lower bounds of weights: ")
print(round(as.numeric(weights_min), digits = 4))
message("\n[times-", times, ", iteration-", iter, "] Updated upper bounds of weights: ")
print(round(as.numeric(weights_max), digits = 4))
message("\n[times-", times, ", iteration-", iter, "] Running time: ")
