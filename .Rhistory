### 5. Define Single Iteration Function ###
# Function to run one iteration with random weights
run_single_iteration = function(nra) {
# Generate random weights for 19 features
rav = runif(n = 19, min = weights_min, max = weights_max)
# Assign weights to named variables
weight_Accessibility = rav[1]
weight_Expression = rav[2]
weight_Accessibility_percentile = rav[3]
weight_Expression_percentile = rav[4]
weight_Accessibility_non_zero_ratio = rav[5]
weight_Expression_non_zero_ratio = rav[6]
weight_Accessibility_non_zero_ratio_percentile = rav[7]
weight_Expression_non_zero_ratio_percentile = rav[8]
weight_peak_importance_score = rav[9]
weight_peak_importance_score_percentile = rav[10]
weight_TG_importance_score = rav[11]
weight_TG_importance_score_percentile = rav[12]
weight_peak_TG_importance_score = rav[13]
weight_peak_TG_importance_score_percentile = rav[14]
weight_TG_count = rav[15]
weight_peak_count = rav[16]
weight_TG_count_percentile = rav[17]
weight_peak_count_percentile = rav[18]
# Note: rav[19] is used for the 'top' parameter (number of top predictions to keep)
# If you do not want to use one or more features, simply modify the code here by setting their weights to 0.
# This is advisable because as the number of parameter dimensions increases, it may become harder to find the optimal solution, since the number of random samples can only increase linearly, while the sampling space grows exponentially.
# This method can be used to retain each feature individually, observe the optimal f1-score obtained from training, and thereby assess the individual importance of each feature.
# Then, only a few important features are retained for further training.
# Keep the best training result, then add one or more new features and continue training.
# Using this strategy is more reliable for achieving relatively optimal results than training with all features at once.
# Calculate weighted importance scores
interest_cell_type_peak_TG_pred = interest_cell_type_peak_TG_pred_bak
peak_TG_df = interest_cell_type_peak_TG_pred[[1]][[level]][["peak_TG"]]
peak_TG_df$peak_TG_IS = as.numeric(as.matrix(peak_TG_df[, c(
"Accessibility", "Expression",
"Accessibility_percentile", "Expression_percentile",
"Accessibility_non_zero_ratio", "Expression_non_zero_ratio",
"Accessibility_non_zero_ratio_percentile", "Expression_non_zero_ratio_percentile",
"peak_importance_score", "peak_importance_score_percentile",
"TG_importance_score", "TG_importance_score_percentile",
"peak_TG_importance_score", "peak_TG_importance_score_percentile",
"TG_count", "peak_count",
"TG_count_percentile", "peak_count_percentile"
)]) %*% c(
weight_Accessibility, weight_Expression,
weight_Accessibility_percentile, weight_Expression_percentile,
weight_Accessibility_non_zero_ratio, weight_Expression_non_zero_ratio,
weight_Accessibility_non_zero_ratio_percentile, weight_Expression_non_zero_ratio_percentile,
weight_peak_importance_score, weight_peak_importance_score_percentile,
weight_TG_importance_score, weight_TG_importance_score_percentile,
weight_peak_TG_importance_score, weight_peak_TG_importance_score_percentile,
weight_TG_count, weight_peak_count,
weight_TG_count_percentile, weight_peak_count_percentile
))
interest_cell_type_peak_TG_pred[[1]][[level]][["peak_TG"]] = peak_TG_df
# Determine number of top predictions to keep
rav19 = round(rav[19])
# Store iteration results
iteration_results = list()
for (top in rav19) { # Preserve the top-based 'for' loop structure, which can be used to iterate over different top values for execution and is intended for use during development
# top = rav19
# Select top predictions
interest_cell_type_peak_TG_pred[[1]][[level]][["peak_TG"]] = interest_cell_type_peak_TG_pred[[1]][[level]][["peak_TG"]] %>%
dplyr::slice_max(peak_TG_IS, n = top)
# Format predictions
scdeds.regionGene = list()
res = interest_cell_type_peak_TG_pred[[1]][[level]][["peak_TG"]]
res1 = do.call(rbind, strsplit(res$peak, "-"))
res2 = data.frame(
seqnames = factor(res1[, 1]),
start = as.numeric(res1[, 2]),
end = as.numeric(res1[, 3]),
width = as.numeric(res1[, 3]) - as.numeric(res1[, 2]) + 1,
strand = factor("*", levels = c("*", "+", "-")),
SYMBOL = res[, "SYMBOL"],
row.names = NULL
)
subset.loci = named.loci[res2$SYMBOL]
names(subset.loci) = NULL
dt = data.frame(
Region = paste0(res2$seqnames, "-", res2$start, "-", res2$end),
Gene = res2$SYMBOL,
Gene.loc = subset.loci
)
scdeds.regionGene[[data.ls]] = dt
# Evaluate predictions
method.list = list(scdeds = scdeds.regionGene)
regionGene.scores = suppressMessages(cal_overlap_regions(r1 = method.list[[1]][[data.ls]], r2 = contacts.ll[[data.ls]]))
df = as.data.frame.list(t(regionGene.scores))
colnames(df) = names(regionGene.scores)
# Create unique name for weight combination
namee = paste(round(c(
weight_Accessibility, weight_Expression,
weight_Accessibility_percentile, weight_Expression_percentile,
weight_Accessibility_non_zero_ratio, weight_Expression_non_zero_ratio,
weight_Accessibility_non_zero_ratio_percentile, weight_Expression_non_zero_ratio_percentile,
weight_peak_importance_score, weight_peak_importance_score_percentile,
weight_TG_importance_score, weight_TG_importance_score_percentile,
weight_peak_TG_importance_score, weight_peak_TG_importance_score_percentile,
weight_TG_count, weight_peak_count,
weight_TG_count_percentile, weight_peak_count_percentile
), digits = 4), collapse = "_")
# Create result data frame
result_df = data.frame(
precision = df[1, "precision"],
recall = df[1, "recall"],
f.score = df[1, "f.score"],
n_peak = dim(scdeds.regionGene[[1]])[1],
n_peak_unique = length(unique(scdeds.regionGene[[1]][["Region"]])),
weight_Accessibility = weight_Accessibility,
weight_Expression = weight_Expression,
weight_Accessibility_percentile = weight_Accessibility_percentile,
weight_Expression_percentile = weight_Expression_percentile,
weight_Accessibility_non_zero_ratio = weight_Accessibility_non_zero_ratio,
weight_Expression_non_zero_ratio = weight_Expression_non_zero_ratio,
weight_Accessibility_non_zero_ratio_percentile = weight_Accessibility_non_zero_ratio_percentile,
weight_Expression_non_zero_ratio_percentile = weight_Expression_non_zero_ratio_percentile,
weight_peak_importance_score = weight_peak_importance_score,
weight_peak_importance_score_percentile = weight_peak_importance_score_percentile,
weight_TG_importance_score = weight_TG_importance_score,
weight_TG_importance_score_percentile = weight_TG_importance_score_percentile,
weight_peak_TG_importance_score = weight_peak_TG_importance_score,
weight_peak_TG_importance_score_percentile = weight_peak_TG_importance_score_percentile,
weight_TG_count = weight_TG_count,
weight_peak_count = weight_peak_count,
weight_TG_count_percentile = weight_TG_count_percentile,
weight_peak_count_percentile = weight_peak_count_percentile,
top = top,
iter = iter,
stringsAsFactors = FALSE
)
iteration_results[[namee]] = result_df
}
return(iteration_results)
}
